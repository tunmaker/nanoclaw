# =============================================================
# nanoclaw environment configuration
# Copy this file to .env and fill in the values.
# =============================================================

# ----- Secrets -----------------------------------------------

# Claude Code CLI OAuth token (used by Claude Code CLI, not nanoclaw app code)
CLAUDE_CODE_OAUTH_TOKEN=

# Telegram bot token (from @BotFather). Required when TELEGRAM_ONLY=true.
TELEGRAM_BOT_TOKEN=

# ----- Identity ----------------------------------------------

# Display name the bot responds to (used in trigger pattern and greetings)
ASSISTANT_NAME=Abbes

# Set to true if the bot's WhatsApp number is a dedicated bot number
# (affects whether messages are prefixed with the assistant name)
ASSISTANT_HAS_OWN_NUMBER=false

# ----- Channel selection -------------------------------------

# Set to true to use Telegram only (WhatsApp disabled).
# Remove or set to false to enable WhatsApp (requires: npm run auth)
TELEGRAM_ONLY=true

# ----- Service URLs ------------------------------------------
# These are normally injected by systemd from config/services.env.
# Override here only if running nanoclaw outside of systemd.

#LOCAL_LLM_URL=http://localhost:8080/v1
#WHISPER_SERVER_URL=http://localhost:8178
#MCP_MEMORY_URL=http://localhost:8052

# ----- Routing -----------------------------------------------
# Forces all messages to the local LLM regardless of privacy classification.
# Still classifies and audit-logs. Set to false to enable Claude routing.
#ROUTE_BYPASS_LOCAL=true

# ----- Logging -----------------------------------------------
# Log level for nanoclaw process (logger.ts, container-runner, mount-security).
# Set independently from mcp-memory LOG_LEVEL (defined in config/mcp-memory.env).
# Valid values: trace, debug, info, warn, error
LOG_LEVEL=info

# ----- Container runtime -------------------------------------
# These have safe defaults in config.ts. Override only if needed.

# Docker image for the Claude Code container
#CONTAINER_IMAGE=nanoclaw-agent:latest

# Max time (ms) to wait for a container run to complete (default: 30 min)
#CONTAINER_TIMEOUT=1800000

# Max stdout+stderr bytes captured from a container (default: 10 MB)
#CONTAINER_MAX_OUTPUT_SIZE=10485760

# Time (ms) before an idle container group queue is torn down (default: 30 min)
#IDLE_TIMEOUT=1800000

# Max number of containers running concurrently across all groups
#MAX_CONCURRENT_CONTAINERS=5

# ----- Timezone ----------------------------------------------
# IANA timezone for scheduled tasks (e.g. "Europe/Paris", "America/New_York").
# Defaults to the system timezone. Set TZ in the OS environment or override here.
#TZ=

# ----- Paths -------------------------------------------------
# Root of the abbes mono-repo. Auto-computed from nanoclaw's location if unset.
# Override only if your directory layout differs from the standard structure.
#ABBES_ROOT=
